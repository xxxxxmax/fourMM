{
  "name": "fourmm",
  "version": "0.1.0",
  "description": "fourMM — agent-first CLI for Four.meme market making on BSC",
  "type": "module",
  "license": "MIT",
  "author": "linwe",
  "keywords": [
    "bsc",
    "four.meme",
    "market-making",
    "agent",
    "cli",
    "defi",
    "meme"
  ],
  "bin": {
    "fourmm": "./dist/bin.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsx src/bin.ts",
    "fourmm": "tsx src/bin.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "incur": "^0.3.25",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@10.32.1"
}
